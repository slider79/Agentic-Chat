# TEMPLATE ONLY - do not put a real key in this file.
# This file IS tracked by git and will be pushed to GitHub.
#
# To use a key locally:
#   1. Copy this file to  .streamlit/secrets.toml   (same folder, drop ".example")
#   2. Put your real key in that copy
#
# secrets.toml is gitignored, so it never leaves your machine.
#
# On Streamlit Cloud, do not upload any file. Paste the line below into
# App settings -> Secrets instead.

GROQ_API_KEY = "gsk_your_key_here"
